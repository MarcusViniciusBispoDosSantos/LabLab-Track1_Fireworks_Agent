# Local/mock testing only. The official harness injects these values.
FIREWORKS_API_KEY=dummy
FIREWORKS_BASE_URL=http://127.0.0.1:8000/v1
ALLOWED_MODELS=mock-model

# Accuracy-first defaults
MODEL_ORDER_STRATEGY=hybrid
BATCH_SOLVE=1
BATCH_CANDIDATES=1
BATCH_MAX_TOKENS=9000
ENSEMBLE_MODE=hard
ENABLE_LOCAL_FAST_PATHS=1
REPAIR_ENABLED=1
MAX_WORKERS=1
MAX_RETRIES=4
HARD_ENSEMBLE_SIZE=2
REQUEST_TIMEOUT_SECONDS=40
