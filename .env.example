# Local/mock only. The lablab judging harness injects these in final evaluation.
FIREWORKS_API_KEY=dummy
FIREWORKS_BASE_URL=http://127.0.0.1:8000/v1
ALLOWED_MODELS=mock-model

# v13 defaults: token-aware accuracy mode.
ENABLE_LOCAL_FAST_PATHS=1
HARD_SECOND_TRY=0
MAX_API_TASKS=999
MAX_WORKERS=1
MODEL_ORDER=hybrid
REQUEST_TIMEOUT_SECONDS=35
MAX_RETRIES=3
