# Local-only example. Do NOT commit a real .env file.
# In official Track 1 evaluation, the judging harness injects these values.
FIREWORKS_API_KEY=dummy
FIREWORKS_BASE_URL=http://127.0.0.1:8000/v1
ALLOWED_MODELS=mock-model

# v5 defaults are accuracy-first.
VERIFY_MODE=all
ENABLE_LOCAL_FAST_PATHS=0
MAX_WORKERS=2
MAX_RETRIES=3
REQUEST_TIMEOUT_SECONDS=29
