# The official judge injects these values. Do not commit a real key.
FIREWORKS_API_KEY=dummy
FIREWORKS_BASE_URL=http://127.0.0.1:8000/v1
ALLOWED_MODELS=mock-model

# Accuracy v4 defaults
VERIFY_MODE=hard
ENABLE_LOCAL_FAST_PATHS=1
ALLOW_THINKING_MODELS=0
MAX_WORKERS=3
MAX_RETRIES=2
REQUEST_TIMEOUT_SECONDS=26
