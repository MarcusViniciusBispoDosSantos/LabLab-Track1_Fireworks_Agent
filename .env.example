# Local/mock testing only. Do not commit a real .env file.
# In the official Track 1 evaluation, the judging harness injects these values.
FIREWORKS_API_KEY=dummy
FIREWORKS_BASE_URL=http://127.0.0.1:8000/v1
ALLOWED_MODELS=mock-model

# Accuracy-first defaults for final submission.
VERIFY_MODE=all
ENABLE_LOCAL_FAST_PATHS=1
MAX_WORKERS=2
MAX_RETRIES=2
REQUEST_TIMEOUT_SECONDS=28

# Local paths if running python directly.
INPUT_PATH=./samples/tasks_all_categories.json
OUTPUT_PATH=./samples/results.json
