# Local development only. Do NOT commit a real .env file.
# In official Track 1 evaluation, the harness injects these variables.
FIREWORKS_API_KEY=dummy
FIREWORKS_BASE_URL=http://127.0.0.1:8000/v1
ALLOWED_MODELS=mock-model
ENABLE_LOCAL_FAST_PATHS=1
RETRY_INVALID_OUTPUTS=1
MAX_WORKERS=3
MAX_RETRIES=5
REQUEST_TIMEOUT_SECONDS=26
ENABLE_MODEL_CALIBRATION=1
CALIBRATION_MODEL_LIMIT=4
