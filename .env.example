# Local development only. Do not commit a real .env file.
FIREWORKS_API_KEY=your_local_key_or_dummy_for_mock
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
ALLOWED_MODELS=accounts/fireworks/models/gpt-oss-120b,accounts/fireworks/models/qwen2p5-coder-32b-instruct,accounts/fireworks/models/llama-v3p3-70b-instruct
VERIFY_MODE=hard
ENABLE_LOCAL_FAST_PATHS=0
MAX_WORKERS=1
MAX_RETRIES=4
REQUEST_TIMEOUT_SECONDS=29
