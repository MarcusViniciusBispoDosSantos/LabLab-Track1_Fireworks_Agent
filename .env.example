# Local development only. Do NOT include a real .env in the Docker image.
# For final Track 1 evaluation, the hackathon harness injects these values.
# You do NOT need to know the real FIREWORKS_API_KEY for final submission.

# Mock-test defaults. These work with scripts/mock_fireworks.py.
FIREWORKS_API_KEY=dummy-harness-key
FIREWORKS_BASE_URL=http://127.0.0.1:8000/v1
ALLOWED_MODELS=mock-model

# To test real AI accuracy locally, replace the three values above with your own
# Fireworks key/base URL/model list. Never commit a real .env file.

# Optional local overrides
INPUT_PATH=./samples/tasks_all_categories.json
OUTPUT_PATH=./samples/results.json
MAX_WORKERS=4
REQUEST_TIMEOUT_SECONDS=28
MAX_RETRIES=2
VERIFY_HARD_TASKS=0
